# Paperama — environment variables
# Copy to .env.local and fill in values as groups ship.

# OpenAlex polite pool (Group 1) — your email
OPENALEX_MAILTO=you@example.com

# Semantic Scholar TLDR lookup (Group 3, optional)
SEMANTIC_SCHOLAR_API_KEY=

# Python enrichment service — sumy summaries + crawl4ai figure URLs (links only)
ENRICHMENT_SERVICE_URL=http://127.0.0.1:8100

# Database (Group 5)
DATABASE_URL=

# Enriched feed index — hero-confirmed papers served without on-demand enrichment
USE_FEED_INDEX=true
ENRICHED_INDEX_PATH=data/enriched-papers.sqlite

# Auth (Group 6) — Clerk or Supabase keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
