{
  "name": "paperama",
  "version": "0.1.0",
  "private": true,
  "description": "Personalized academic paper discovery feed",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:d1:migrate": "wrangler d1 migrations apply paperama-feed-index",
    "cf:d1:export-index": "npx tsx scripts/export-index-sql.ts",
    "cf:d1:seed-remote": "npm run cf:d1:export-index && wrangler d1 execute paperama-feed-index --remote --file data/enriched-papers.seed.sql",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "smoke:openalex": "npx tsx scripts/smoke-openalex.ts",
    "smoke:feed": "npx tsx scripts/smoke-feed.ts",
    "smoke:figures": "npx tsx scripts/smoke-figures.ts",
    "smoke:enrichment": "npx tsx scripts/smoke-enrichment.ts",
    "fill:topic": "npx tsx scripts/fill-topic.ts",
    "fill:all-topics": "npx tsx scripts/fill-all-topics.ts",
    "setup:enrichment": "powershell -ExecutionPolicy Bypass -File scripts/setup-enrichment.ps1",
    "enrichment:dev": "services/enrichment/.venv/Scripts/python.exe -m uvicorn main:app --reload --host 127.0.0.1 --port 8100 --app-dir services/enrichment"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tufte-css": "^1.9.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.108.0"
  }
}
